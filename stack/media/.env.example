# Media Stack Environment Variables
# Copy this file to .env and configure with your credentials

# =============================================================================
# VPN Configuration (Required for Gluetun)
# =============================================================================

# Provider options: protonvpn, mullvad, nordvpn, pia, surfshark, etc.
# See: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_SERVICE_PROVIDER=protonvpn

# WireGuard credentials from VPN provider dashboard
# ProtonVPN: account.protonvpn.com -> Downloads -> WireGuard configuration
WIREGUARD_PRIVATE_KEY=your-wireguard-private-key
WIREGUARD_ADDRESSES=10.2.0.2/32

# Optional: Server location preference
SERVER_COUNTRIES=United States

# =============================================================================
# qBittorrent Credentials (for arr app download client config)
# =============================================================================
# Default password set by LinuxServer image on first start
# Change this in qBittorrent UI and update here
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin
QBIT_HOST=gluetun
QBIT_PORT=8080

# =============================================================================
# Bootstrap Credentials (default for all services)
# =============================================================================
# Change these after first login!
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=Ragnalab2026

# =============================================================================
# API Keys (Auto-populated by bootstrap scripts)
# =============================================================================
# These are generated by each service on first start.
# The bootstrap scripts will extract and save them here.
# Leave empty for fresh install - scripts will populate them.

SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=
JELLYFIN_API_KEY=
JELLYSEERR_API_KEY=
