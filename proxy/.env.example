# Cloudflare API credentials for DNS-01 challenge
# Get your API token from: Cloudflare Dashboard -> My Profile -> API Tokens
# Use "Edit zone DNS" template, scope to ragnalab.xyz zone only
CF_API_EMAIL=your-email@example.com
CF_DNS_API_TOKEN=your-cloudflare-api-token

# Let's Encrypt email for certificate expiry notifications
ACME_EMAIL=your-email@example.com

# Domain configuration
DOMAIN=ragnalab.xyz
