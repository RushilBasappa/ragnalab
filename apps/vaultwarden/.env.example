# Vaultwarden Configuration
# Copy to .env and fill in values

# Admin Token (REQUIRED)
# Generate with: docker run --rm -it vaultwarden/server /vaultwarden hash
# Enter a secure password when prompted, then copy the output hash.
# Use single quotes to avoid shell interpretation of $ symbols in the hash.
VAULTWARDEN_ADMIN_TOKEN='<paste-argon2id-hash-here>'

# SMTP Configuration (Optional - for sending invitation emails)
# Without SMTP, use admin panel to manually create users.
# Note: SMTP is not configured in docker-compose.yml by default because
# Vaultwarden validates strictly - empty SMTP_HOST with any SMTP_* vars causes
# startup failure. To enable email, add these to docker-compose.yml environment:
#   SMTP_HOST: smtp.example.com
#   SMTP_FROM: vaultwarden@example.com
#   SMTP_PORT: 587
#   SMTP_SECURITY: starttls
#   SMTP_USERNAME: user
#   SMTP_PASSWORD: password
