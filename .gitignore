*.env
!*.env.example

# MkDocs build output
site/

# Archived old directory structure (pre-stack migration)
archive/

# Pi-hole data directories (not version controlled)
stack/infra/pihole/etc-pihole/
stack/infra/pihole/etc-dnsmasq.d/
